[Argument]
PingMe = switch,true,tag=PingMe иҺ·еҸ– Cookie
WeTalk = switch,true,tag=WeTalk иҺ·еҸ– Cookie
PM = input,"25 2-23/6 * * *",tag= PingMe е®ҡж—¶
WT = input,"20 2-23/6 * * *",tag= WeTalk е®ҡж—¶

[Rule]
DOMAIN, api.pingmeapp.net,  йҰҷжёҜж—¶е»¶дјҳйҖү

[Script]
cron {PM} script-path=https://raw.githubusercontent.com/ZenmoFeiShi/Qx/refs/heads/main/PingMe.js, timeout=600,enable= {arg1},tag=PingMeзӯҫеҲ°д»»еҠЎ
cron {WT} script-path=https://raw.githubusercontent.com/ZenmoFeiShi/Qx/refs/heads/main/WeTalk.js, timeout=600,enable= {arg2},tag=WeTalkзӯҫеҲ°д»»еҠЎ
http-request ^https:\/\/api\.pingmeapp\.net\/app\/queryBalanceAndBonus script-path=https://raw.githubusercontent.com/fmz200/wool_scripts/main/Scripts/cookie/get_cookie.js, timeout=300, enable = {PingMe}, tag=PingMeиҺ·еҸ– Cookie
http-request ^https:\/\/api\.wetalkapp\.com\/app\/queryBalanceAndBonus script-path=https://raw.githubusercontent.com/SXIE-ai/Loon/refs/heads/main/plugins/WeTalk/Cookie.js, timeout=300, enable = {WeTalk}, tag=WeTalkиҺ·еҸ– Cookie
[MITM]
hostname = api.pingmeapp.net, api.wetalkapp.com
