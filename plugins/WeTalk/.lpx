#!name=WeTalk
#!desc=自动化签到➕视频奖励
#!openUrl=https://apps.apple.com/us/app/id455447012
#!author=SXIE-ai[https://github.com/SXIE-ai]
#!homepage=https://github.com/SXIE-ai/loon/plugins
#!icon=https://raw.githubusercontent.com/SXIE-ai/Loon/main/plugins/icon/icons/WeTalk.png
#!tag=签到
#!loon_version=3.4.0（962)
#!date=2026-6-19

[Argument]
WeTalk_enable = switch,true,false,tag= WeTalk 获取 Cookie
  
[Script]
# WeTalk 获取 Cookie
http-request https://api.wetalkapp.com/app/queryBalanceAndBonus script-path=https://raw.githubusercontent.com/ZenmoFeiShi/Qx/refs/heads/main/WeTalk.js, require-body=false,tag=WeTalk获取 Cookie,enable={WeTalk_enable}

# WeTalk 自动签到任务
cron "25 2-23/6 * * *" script-path=https://raw.githubusercontent.com/ZenmoFeiShi/Qx/refs/heads/main/WeTalk.js, tag=WeTalk签到, timeout=60

  

[MITM]
hostname = api.wetalkapp.com

